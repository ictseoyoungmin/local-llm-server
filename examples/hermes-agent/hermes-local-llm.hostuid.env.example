# Copy to .env.hermes-local-llm-hostuid before running
# docker-compose.hermes-local-llm.yml.
#
# This mode reproduces the host-bind strategy used by
# F:\NowWorking\hermes-agent: bind a host directory to /opt/data and run Hermes
# as the WSL host uid/gid. It is useful for portability experiments, but the
# Docker named-volume runtime remains the default stable mode.

HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_COMPOSE_PROJECT_NAME=hermes-local-llm-hostuid
HERMES_CONTAINER_NAME=local-llm-hermes-local-hostuid

HERMES_HOME_DIR=./.hermes-local-llm-hostuid
HERMES_SEED_DIR=./.hermes-runtime-example
HERMES_TUI_DIST_DIR=./.hermes-local-llm-hostuid-ui-tui-dist

HERMES_UID=1000
HERMES_GID=1000
DOCKER_GID=1001

HERMES_API_PORT=48642
HERMES_DASHBOARD_PORT=49119
API_SERVER_KEY=change-me-local-hermes-key
API_SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
OPENAI_BASE_URL=http://host.docker.internal:18080/v1
OPENAI_API_KEY=local-not-required

# Localhost-only example default. Set to false and configure explicit platform
# allowlists before exposing the gateway/dashboard beyond 127.0.0.1.
GATEWAY_ALLOW_ALL_USERS=true

# Keep existing /opt/data/config.yaml and /opt/data/SOUL.md by default.
# Set to 1 to reseed from .hermes-runtime-example/ and create .bak timestamps.
HERMES_OVERWRITE_CONFIG=0

# Browser tool runtime. The default points at the Chromium headless shell
# bundled in the Hermes image.
AGENT_BROWSER_EXECUTABLE_PATH=/opt/hermes/.playwright/chromium_headless_shell-1217/chrome-headless-shell-linux64/chrome-headless-shell
PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright
