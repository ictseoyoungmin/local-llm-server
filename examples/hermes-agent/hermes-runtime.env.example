# Copy to .env.hermes-runtime before running docker-compose.hermes-runtime.example.yml.
# This example is for localhost-only development. Replace API_SERVER_KEY before
# exposing Hermes beyond 127.0.0.1.
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_COMPOSE_PROJECT_NAME=local-llm-hermes-runtime
HERMES_CONTAINER_NAME=local-llm-hermes
HERMES_HOME_DIR=./.hermes-runtime-example

HERMES_UID=1000
HERMES_GID=1000
DOCKER_GID=1001

HERMES_API_PORT=8642
HERMES_DASHBOARD_PORT=9119
API_SERVER_KEY=change-me-local-hermes-key
API_SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Optional. Leave blank unless agent-browser Chrome is installed in the mounted
# Hermes home directory.
AGENT_BROWSER_EXECUTABLE_PATH=
