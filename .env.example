# Host directory that contains GGUF files.
HOST_MODEL_DIR=./models

# Path inside the llama.cpp container.
LLAMA_MODEL_PATH=/models/model.gguf
LLAMA_MMPROJ_PATH=/models/mmproj.gguf

# Public model name reported by /v1/health and useful for client configs.
PUBLIC_MODEL_NAME=local-llama

# Optional Hugging Face download settings.
# Many gated model repos require:
#   huggingface-cli login
# or:
#   export HF_TOKEN=...
HF_MODEL_REPO=
HF_MODEL_FILE=
HF_MMPROJ_FILE=

# llama.cpp runtime settings.
LLAMA_HOST=0.0.0.0
LLAMA_PORT=8080
LLAMA_CTX_SIZE=81920
LLAMA_THREADS=8
LLAMA_PARALLEL=1

# GPU override settings. Used with docker-compose.gpu.example.yml.
# -1 means offload all possible layers.
LLAMA_GPU_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_N_GPU_LAYERS=-1

# Gateway settings.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
LLAMA_UPSTREAM_BASE_URL=http://llama:8080/v1
LOCAL_LLM_API_KEY=local-not-required
REQUEST_TIMEOUT_SECONDS=600
